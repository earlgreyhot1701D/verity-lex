# Verity Lex — copy this to .env.local and fill in real values.
# NEVER commit real keys. These are read only in server code (API routes),
# never shipped to the client bundle.

# OpenAI — GPT-5.6 (reasoning: extraction, explanation, training/draft add-ons)
OPENAI_API_KEY=sk-your-key-here

# Tavily — agent search + retrieval (the discover tool)
TAVILY_API_KEY=tvly-your-key-here

# Optional overrides
# OPENAI_MODEL=gpt-5.6
# AGENT_MAX_ITERATIONS=8
# AGENT_MAX_FETCHES=12
